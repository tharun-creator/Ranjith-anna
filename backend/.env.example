APP_ENV=production
APP_NAME=TrailRide
APP_VERSION=0.1.0
DEBUG=false
ALLOWED_ORIGINS=["https://your-frontend-domain.com"]
OAUTHLIB_RELAX_TOKEN_SCOPE=1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Auth — RS256 JWT ─────────────────────────────────────────────────────────
# Paste your RSA private and public keys here (make sure newlines are correct)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=RS256

# ── Encryption ───────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=generate_a_64_character_hex_string_here

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EXTRACTION_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SECONDS=60

# ── Google OAuth & Gmail API ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/v1/gmail/callback
GEMINI_API_KEY=your_gemini_api_key_here
OAUTHLIB_INSECURE_TRANSPORT=0

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
GCP_PUBSUB_TOPIC=gmail-notifications
GCP_PUBSUB_SUBSCRIPTION=gmail-notifications-sub
GCP_PUBSUB_VERIFICATION_TOKEN=generate_a_secure_token_for_webhooks_here

# ── Confidence thresholds ────────────────────────────────────────────────────
CONFIDENCE_AUTO_POST_THRESHOLD=95
CONFIDENCE_REVIEW_THRESHOLD=75

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com
